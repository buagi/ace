set -uo pipefail
ACE_VERSION="0.0.2-alpha"
ACE_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
for m in ui core dash architecture install scaffold gitflow vps audit consistency menu; do source "$ACE_DIR/lib/$m.sh"; done

detect_distro
log_init
activate_paths 2>/dev/null || true
# appearance: env ACE_THEME/ACE_NO_ANIM/ACE_ART win; else fall back to stored prefs
apply_theme "${ACE_THEME:-$(config_get THEME 2>/dev/null || true)}"
: "${ACE_NO_ANIM:=$(config_get NO_ANIM 2>/dev/null || true)}"; : "${ACE_ART:=$(config_get ART 2>/dev/null || true)}"; ACE_ART="${ACE_ART:-auto}"

# ----------------------------------------------------------------- doctor / status
drow() {
  local s="$1" n="$2" d="${3:-}"
  case "$s" in
    ok)   printf '  %s✓%s %-22s %s%s%s\n' "$C_GREEN" "$C_RESET" "$n" "$C_GREY" "$d" "$C_RESET" ;;
    warn) printf '  %s!%s %-22s %s%s%s\n' "$C_YELLOW" "$C_RESET" "$n" "$C_GREY" "$d" "$C_RESET" ;;
    bad)  printf '  %s✗%s %-22s %s%s%s\n' "$C_RED" "$C_RESET" "$n" "$C_GREY" "$d" "$C_RESET" ;;
    *)    printf '  %s·%s %-22s %s%s%s\n' "$C_CYAN" "$C_RESET" "$n" "$C_GREY" "$d" "$C_RESET" ;;
  esac
}
chk() { have "$1" && drow ok "$1" "$(ver "$1")" || drow bad "$1" "not installed"; }

# refuse a dangerous op when running headless (no human) unless --confirm / ACE_CONFIRM=1 was passed
_gate_destructive() {
  if _noninteractive && [ "${ACE_CONFIRM:-0}" != 1 ]; then
    err "'$1' is gated when non-interactive — re-run with --confirm to proceed."; return 1
  fi
  return 0
}

doctor() {
  banner; step "Status — system check"
  drow info "distro" "$ACE_DISTRO_PRETTY ($ACE_DISTRO)"
  local eng; eng="$(container_engine)"
  [ -n "$eng" ] && drow ok "container engine" "$eng" || drow bad "container engine" "podman/docker missing (ci --container needs it)"
  hr
  for t in node fnm uv uvx bun jq opencode npx; do chk "$t"; done
  hr
  if have gh; then
    drow ok "gh" "$(ver gh)"
    if gh auth status >/dev/null 2>&1; then drow ok "gh auth" "logged in as $(gh api user -q .login 2>/dev/null || echo '?')"
    else drow warn "gh auth" "not logged in (run: ace git)"; fi
  else drow bad "gh" "not installed"; fi
  local gn ge; gn="$(git config --global user.name 2>/dev/null || true)"; ge="$(git config --global user.email 2>/dev/null || true)"
  [ -n "$gn" ] && [ -n "$ge" ] && drow ok "git identity" "$gn <$ge>" || drow warn "git identity" "set user.name/email (ace git)"
  hr
  if [ -n "${DEEPSEEK_API_KEY:-}" ]; then
    if validate_deepseek_key "$DEEPSEEK_API_KEY"; then drow ok "DeepSeek key" "valid (v4 models reachable)"
    else drow bad "DeepSeek key" "set but REJECTED by API"; fi
  else drow bad "DeepSeek key" "not set (run: ace keys)"; fi
  [ -n "${CONTEXT7_API_KEY:-}" ] && drow ok "Context7 key" "set" || drow warn "Context7 key" "unset (works, rate-limited)"
  [ -f "$HOME/.config/opencode/opencode.json" ] && drow ok "opencode config" "~/.config/opencode/opencode.json" || drow warn "opencode config" "not written (ace opencode)"
  hr
  if vps_configured; then drow ok "VPS" "${VPS_USER}@${VPS_HOST}:${VPS_PORT:-22}  os=${VPS_OS:-?}"
  else drow warn "VPS" "not configured (ace vps)"; fi
  # Go toolchain — shown when go is installed or the current repo is a Go project
  if have go || grep -q '^language: go' .opencode/profile.yaml 2>/dev/null; then
    hr
    if have go; then drow ok "go" "$(go version 2>/dev/null | awk '{print $3}')"; else drow bad "go" "not installed (run: ace install)"; fi
    local gt; for gt in gopls staticcheck govulncheck garble; do have "$gt" && drow ok "$gt" "present" || drow warn "$gt" "missing (ace install)"; done
    if [ -f .opencode/profile.yaml ] && [ -n "$(_prof_get shape 2>/dev/null)" ]; then
      drow info "go profile" "shape=$(_prof_get shape) · deploy=$(_prof_get deploy_kind) · hardening=$(_prof_get hardening)"
    fi
  fi
  hr
  local vx=""; for t in chafa figlet toilet freeze ansitoimg; do have "$t" && vx="$vx ${C_GREEN}$t✓${C_RESET}" || vx="$vx ${C_GREY}$t✗${C_RESET}"; done
  local cap=8color; [ "$ACE_TC" = 1 ] && cap=truecolor || { [ "$ACE_COLOR" = 1 ] && cap=256color || cap=no-color; }
  drow info "appearance" "theme=${_ACE_THEME:-warp} · $cap · art=${ACE_ART:-auto} · extras:$vx"
  drow info "hermes/chat" "target=$(hermes_to) · snap=$(have freeze && echo freeze || { have ansitoimg && echo ansitoimg || echo 'none (ace install)'; }) · hermes=$(have hermes && echo wired || echo absent)"
  local prof; prof="$(config_get MODEL_PROFILE)"
  printf '\n%s\n' "${C_GREY}profile: ${prof:-unset}  •  dry-run: $ACE_DRY_RUN  •  log: $ACE_LOG_FILE${C_RESET}"
  # when run inside a repo, also surface repo drift (git/gitnexus/opencode/podman)
  _con_in_repo && { hr; consistency_report || true; }
  hr; readiness_report
}

# readiness_report — the plain-language "what works now / what still needs setup" summary. Classifies each
# capability into READY / NEEDS-SETUP (with the exact fix command + what it unlocks) / OPTIONAL, ending with a
# single verdict. Shown at the end of `ace status` AND after `ace install`, so a user always knows exactly
# where they stand and what to do next. Read-only.
readiness_report() {
  step "Readiness — what's functional, what still needs setup"
  local ready=() need=() opt=() x
  [ -n "$(container_engine 2>/dev/null)" ] && ready+=("container gate — the ./ci.sh --container merge check") \
    || need+=("container engine (podman/docker) — nothing can be gate-verified without it")
  [ -n "${DEEPSEEK_API_KEY:-}" ] && ready+=("model key — the 10-agent crew can run") \
    || need+=("model key → run  ace keys   (the crew cannot run without it)")
  { have gh && gh auth status >/dev/null 2>&1; } && ready+=("GitHub — PRs · merges · CI-watch") \
    || need+=("GitHub login → run  ace git   (autorun works by opening/merging PRs)")
  { git config --global user.name >/dev/null 2>&1 && git config --global user.email >/dev/null 2>&1; } \
    && ready+=("git identity") || need+=("git identity → run  ace git")
  [ -f "$HOME/.config/opencode/opencode.json" ] && ready+=("agent config (~/.config/opencode/opencode.json)") \
    || need+=("agent config → run  ace opencode")
  vps_configured 2>/dev/null && ready+=("VPS deploy target") || opt+=("VPS deploy → run  ace vps   (only if you ship to a server)")
  [ -n "${CONTEXT7_API_KEY:-}" ] && opt+=("Context7 key set (faster library-doc lookups)") \
    || opt+=("Context7 key — optional (library docs still work, rate-limited)")
  if curl -fsS -m 2 "http://127.0.0.1:${FIRECRAWL_PORT:-3002}/" >/dev/null 2>&1; then
    ready+=("Firecrawl research (LOCAL · loopback-only · boosts feature research)")
  else opt+=("Firecrawl research → run  ace firecrawl up   (optional; local research crawler)"); fi
  printf '\n %sREADY NOW%s\n' "${C_GREEN}${C_BOLD:-}" "$C_RESET"; for x in "${ready[@]}"; do printf '   %s✓%s %s\n' "$C_GREEN" "$C_RESET" "$x"; done
  [ ${#need[@]} -gt 0 ] && { printf '\n %sNEEDS SETUP before a live run%s\n' "${C_GOLD}${C_BOLD:-}" "$C_RESET"; for x in "${need[@]}"; do printf '   %s⚠%s %s\n' "$C_GOLD" "$C_RESET" "$x"; done; }
  [ ${#opt[@]} -gt 0 ] && { printf '\n %soptional%s\n' "$C_GREY" "$C_RESET"; for x in "${opt[@]}"; do printf '   %s◦%s %s\n' "$C_GREY" "$C_RESET" "$x"; done; }
  if [ ${#need[@]} -eq 0 ]; then printf '\n %s✔ READY — you can run:  ace autorun   ·   ace swarm start%s\n' "${C_GREEN}${C_BOLD:-}" "$C_RESET"
  else printf '\n %s⚠ NOT READY — clear the %d item(s) above, then re-check with  ace status%s\n' "${C_GOLD}${C_BOLD:-}" "${#need[@]}" "$C_RESET"; fi
  printf ' %sfull log: %s%s\n' "$C_GREY" "${ACE_LOG_FILE:-$ACE_LOG_DIR/ace-<date>.log}" "$C_RESET"
}

logs() {
  local f; f="$(ls -t "$ACE_LOG_DIR"/ace-*.log 2>/dev/null | head -1)"
  [ -n "$f" ] || { warn "no logs yet"; return; }
  step "Logs — $f (last 40 lines)"; tail -n 40 "$f"
}

update() {
  banner; step "Update tooling"
  have opencode && spin "opencode upgrade" opencode upgrade || true
  have bun      && spin "bun upgrade" bun upgrade || true
  have fnm      && spin_sh "Node LTS refresh" 'fnm install --lts && fnm default lts-latest' || true
  have uv       && spin "uv self update" uv self update || true
  ensure_hermes_skill   # re-sync the Hermes 'ace' skill to this CLI version (no-op without Hermes)
  ensure_loop_unit      # upgrade an already-installed ace-loop.service to the current OOM/restart guards
  ok "Done. (gh: re-run 'ace git' to refresh.)"
}

# ----------------------------------------------------------------- guided
guided() {
  banner; step "Full guided setup"
  box "This will (each step logged; --dry-run to preview)" \
    "1. host tools (fnm/node, uv, bun, jq, opencode) — user-local" \
    "2. DeepSeek (validated) + Context7 keys + model profile" \
    "3. OpenCode config (10 agents: orchestrator/implementer/test_engineer/verifier + 4 critics + conflict_resolver + launch_readiness_reviewer + MCP)" \
    "4. git identity + GitHub login (gh)" \
    "5. optional: scaffold a project + VPS deploy"
  confirm "Proceed?" Y || return
  ACE_STEP=0; ACE_STEPS=5
  progress "Host tooling";        install_host_tools
  progress "API keys";            configure_keys
  progress "OpenCode config";     write_opencode_config
  progress "Git + GitHub";        setup_git_github
  progress "Project (optional)";  confirm "Scaffold a project now?" Y && scaffold_project || info "skipped scaffolding"
  ensure_hermes_skill   # if Hermes is present, install/refresh its 'ace' chat skill (stamped to this version)
  ensure_loop_unit      # upgrade an already-installed ace-loop.service to the current OOM/restart guards
  step "All done"; ok "Run 'ace status' to re-check anytime, then 'cd <project> && opencode'."
  hr; readiness_report   # tell the user plainly what's functional now and what still needs a step
  note_new_shell
}

# ----------------------------------------------------------------- uninstall
uninstall() {
  banner; step "Uninstall / clean (ACE-managed bits only)"
  warn "Removes ACE's managed pieces only. Your projects and code are NOT touched."
  if confirm "Remove the managed block from ~/.bashrc?" N; then
    [ "$ACE_DRY_RUN" = 1 ] || { awk -v b="$ACE_MARK_BEGIN" -v e="$ACE_MARK_END" '$0==b{s=1} !s{print} $0==e{s=0}' "$BASHRC" > "$BASHRC.t" && mv "$BASHRC.t" "$BASHRC"; }
    ok "bashrc block removed (backup at ~/.bashrc.ace.bak)."
  fi
  confirm "Delete ~/.config/ace (keys, vps, config, logs)?" N && { run rm -rf "$ACE_CONFIG_DIR"; ok "ACE config removed."; }
  confirm "Delete ~/.config/opencode?" N && { run rm -rf "$HOME/.config/opencode"; ok "OpenCode config removed."; }
  say "${C_GREY}Host tools (fnm/uv/bun/opencode/gh) left in place.${C_RESET}"
}

