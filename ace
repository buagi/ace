# ----------------------------------------------------------------- dispatch
# Flags map to ACE_*/PROFILE_* env so any flow runs non-interactively (Hermes drives it step-by-step).
# Value-taking flags consume the next arg; everything else falls through to cmd / ACE_ARG / ACE_ARG2.
cmd=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) ACE_DRY_RUN=1; export ACE_DRY_RUN ;;
    --watch) ACE_WATCH=1 ;;
    --yes|-y) ACE_YES=1; export ACE_YES ;;
    --confirm) ACE_CONFIRM=1; export ACE_CONFIRM ;;          # unlock the gated destructive ops
    --version|-V) echo "ace $ACE_VERSION"; exit 0 ;;
    --help|-h) usage; exit 0 ;;
    --name)       ACE_NAME="${2:-}"; export ACE_NAME; shift ;;
    --path|--dir) ACE_PARENT="${2:-}"; export ACE_PARENT; shift ;;
    --stack)      ACE_STACK="${2:-}"; export ACE_STACK; shift ;;
    --shape)      ACE_SHAPE="${2:-}"; export ACE_SHAPE; shift ;;
    --ci)         ACE_CI="${2:-}"; export ACE_CI; shift ;;
    --deploy)     ACE_DEPLOY="${2:-}"; export ACE_DEPLOY; shift ;;   # service|none
    --gitflow)    ACE_GITFLOW=true;  export ACE_GITFLOW ;;
    --no-gitflow) ACE_GITFLOW=false; export ACE_GITFLOW ;;
    --no-git)       ACE_GIT=false;       export ACE_GIT ;;        # no git at all (implies no CI/VPS/publish)
    --no-ci)        ACE_CI=none;         export ACE_CI ;;         # no CI/CD workflow (alias of --ci none)
    --no-vps)       ACE_DEPLOY=none;     export ACE_DEPLOY ;;     # no VPS deploy (alias of --deploy none)
    --container)    ACE_CONTAINER=true;  export ACE_CONTAINER ;;  # container parity gate (default)
    --no-container) ACE_CONTAINER=false; export ACE_CONTAINER ;;  # host-only gate, no Containerfile
    --audience)   ACE_AUDIENCE="${2:-}";   export ACE_AUDIENCE;   shift ;;  # internal|oss-public|end-customer|enterprise
    --throughput) ACE_THROUGHPUT="${2:-}"; export ACE_THROUGHPUT; shift ;;  # low|medium|high
    --domain)     ACE_DOMAIN="${2:-}";     export ACE_DOMAIN;     shift ;;  # one-line description
    --mission)    ACE_MISSION="${2:-}";    export ACE_MISSION;    shift ;;  # why it exists (one line)
    --check)      ACE_ARG=check;   export ACE_ARG ;;   # ace profile --check  (also works as 'ace profile check')
    --force)      ACE_ARG=force;   export ACE_ARG ;;   # ace deploy --force (bypass the DEPLOY_GATE=release milestone gate)
    --explain)    ACE_ARG=explain; export ACE_ARG ;;   # ace autorun --explain
    --demo)       ACE_DEMO=1;      export ACE_DEMO ;;  # ace loop dash --demo (scripted preview)
    --index)      ACE_INDEX=1;   export ACE_INDEX ;;
    --publish)    ACE_PUBLISH=1; export ACE_PUBLISH ;;
    --deepseek)   DEEPSEEK_API_KEY="${2:-}"; export DEEPSEEK_API_KEY; shift ;;
    --context7)   CONTEXT7_API_KEY="${2:-}"; export CONTEXT7_API_KEY; shift ;;
    --profile)    ACE_PROFILE="${2:-}"; export ACE_PROFILE; shift ;;  # keys: max|high|balanced
    --brain)      ACE_BRAIN="${2:-}";   export ACE_BRAIN;   shift ;;  # keys: opus(default)|sonnet|gpt|deepseek
    --to)         ACE_TO="${2:-}";  export ACE_TO;  shift ;;          # snap target
    --out)        ACE_OUT="${2:-}"; export ACE_OUT; shift ;;          # snap output path
    --tag)        ACE_RELEASE_TAG="${2:-}"; export ACE_RELEASE_TAG; shift ;;  # ace release --tag vX.Y.Z (cut+push a v* tag → CI release job)
    --host)       ACE_RELEASE_HOST=1; export ACE_RELEASE_HOST ;;  # ace release --host (build on the host, not in a container)
    -*) ;;        # ignore unknown flags
    *) if [ -z "$cmd" ]; then cmd="$1"; elif [ -z "${ACE_ARG:-}" ]; then ACE_ARG="$1"; elif [ -z "${ACE_ARG2:-}" ]; then ACE_ARG2="$1"; elif [ -z "${ACE_ARG3:-}" ]; then ACE_ARG3="$1"; fi ;;
  esac
  shift
done

case "${cmd:-menu}" in
  menu)              alt_screen_on; trap 'alt_screen_off' EXIT INT TERM; main_menu; alt_screen_off; trap - EXIT INT TERM ;;
  status|doctor)     doctor ;;
  install|guided)    guided ;;
  keys)              configure_keys ;;
  opencode)          write_opencode_config ;;
  settings|config)   settings_menu ;;
  scaffold|new)      scaffold_project ;;
  snap|snapshot)     ace_snap ;;
  snapcard)          snap_card ;;            # internal: banner + compact status (snapshot content)
  profile)           cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)" 2>/dev/null || true; case "${ACE_ARG:-}" in --check|check) profile_check ;; *) profile_wizard; _profile_postcheck ;; esac ;;
  publish)           cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)" 2>/dev/null || true; publish_repo "${ACE_ARG:-}" ;;   # create+push the GitHub repo, or re-push/rename if it already exists
  package)           add_workspace_package "${ACE_ARG:-}" ;;
  stack)             case "${ACE_ARG:-}" in add) stack_add "${ACE_ARG2:-}" ;; *) stack_list ;; esac ;;
  import)            import_existing ;;
  graph)             [ "${ACE_WATCH:-0}" = 1 ] && graph_watch || graph_refresh ;;
  atlas)             atlas_refresh ;;
  demo)              bash "$ACE_DIR/scripts/demo.sh" ;;   # paced, zero-credit feature tour (for a demo video)
  autoloop|autorun|loop|resume)
    case "${ACE_ARG:-}" in
      start|stop|restart|status|logs|tail|stats|metrics|up|update) loop_ctl "$ACE_ARG" ;;
      dash|dashboard)    loop_dash ;;
      --explain|explain) cd "$(git rev-parse --show-toplevel 2>/dev/null || pwd)" 2>/dev/null || true; autorun_explain ;;
      *) autoloop_run ;;
    esac ;;
  loop-service)      loop_service_run "${ACE_ARG:-}" ;;   # internal: systemd ExecStart target
  report|triage)     _sl="$(dirname "$(readlink -f "$0")")/lib"; . "$_sl/report.sh"
                     if [ "$cmd" = triage ] || [ "${ACE_ARG:-}" = triage ]; then ace_triage
                     else ace_report "${ACE_ARG:-note}" "${ACE_ARG2:-repo}" "manual report via ace report"; fi ;;
  stats)             _sl="$(dirname "$(readlink -f "$0")")/lib"; . "$_sl/telemetry.sh"; ace_stats "${ACE_ARG:-}" "${ACE_ARG2:-}" "${ACE_ARG3:-}" ;;
  quality)           _sl="$(dirname "$(readlink -f "$0")")/lib"; . "$_sl/telemetry.sh"; ace_quality ;;
  swarm)             _sr="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"; _sl="$(dirname "$(readlink -f "$0")")/lib"
                     case "${ACE_ARG:-}" in
                       start)     if [ "${ACE_ARG2:-}" = fg ]; then ( cd "$_sr" && SWARM_LIVE=1 DRY_RUN=0 SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" start )
                                  else ( cd "$_sr" && SWARM_LIVE=1 DRY_RUN=0 SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" startd )
                                       # after it prints its flags, drop straight into the live cockpit (unless piped or opted out)
                                       [ -t 1 ] && [ -t 0 ] && [ "${ACE_NO_DASH:-0}" != 1 ] && ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" dash ); fi ;;
                       stop)      ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" stop ) ;;
                       dash|watch)( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" dash ) ;;
                       split)     ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" split ) ;;
                       pause)     ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" pause ) ;;
                       resume)    ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" resume ) ;;
                       drain)     ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" drain ) ;;
                       kill)      ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" kill "${ACE_ARG2:?ace swarm kill wN}" ) ;;
                       status)    ( cd "$_sr" && bash "$_sl/swarm.sh" status ) ;;
                       stats)     ( cd "$_sr" && REPO="$_sr" bash "$_sl/swarm.sh" stats ) ;;
                       preflight) ( cd "$_sr" && SWARM_REPO="$_sr" bash "$_sl/swarm-run.sh" preflight ) ;;
                       tail|logs) ( cd "$_sr" && bash "$_sl/swarm.sh" tail "${ACE_ARG2:-40}" ) ;;
                       sandbox)   bash "$_sl/swarm-run.sh" sandbox ;;
                       selftest)  bash "$_sl/swarm.sh" selftest && bash "$_sl/swarm.sh" waittest && bash "$_sl/swarm.sh" redmain-selftest && bash "$_sl/swarm.sh" abandon-selftest && bash "$_sl/swarm.sh" owns-selftest && bash "$_sl/swarm.sh" plan-lint-selftest ;;
                       policy)    ( cd "$_sr" && bash "$_sl/swarm.sh" policy ) ;;
                       policy-selftest) bash "$_sl/swarm.sh" policy-selftest ;;
                       wire)      bash "$_sl/swarm-wire.sh" "${ACE_ARG2:-check}" "$_sr" ;;
                       *) echo "usage: ace swarm {start[ fg]|stop|dash|split|pause|resume|drain|kill wN|status|stats|tail|sandbox|selftest|policy|wire [check|apply]}" ;;
                     esac ;;
  awake|caffeinate)  awake_ctl "${ACE_ARG:-status}" ;;
  upgrade|adopt)     upgrade_repo ;;
  git)               setup_git_github ;;
  gitflow|git-flow)  git_flow_apply "$PWD" ;;
  protect)           gh_protect_main ;;
  audit)             ace_audit ;;
  consistency|drift|scope) consistency_cmd ;;
  vps)               case "${ACE_ARG:-}" in check|doctor|readiness) vps_check ;; harden) _gate_destructive "vps harden" && vps_harden ;; *) vps_menu ;; esac ;;
  deploy)            _gate_destructive deploy && vps_deploy ;;
  release)           release_run ${ACE_ARG:+"$ACE_ARG"} ${ACE_RELEASE_HOST:+--host} ;;
  healthcheck|health) vps_healthcheck ;;
  verify)            vps_verify ;;
  logs)              logs ;;
  hermes|notify)     case "${ACE_ARG:-}" in mcp) ace_hermes_mcp ;; webhook) ace_hermes_webhook ;; *) ace_hermes ;; esac ;;
  brain)             ace_brain ;;                                    # file ACE lessons into gbrain (if present)
  approve)           ace_approve "${ACE_ARG:-}" "${ACE_ARG2:-}" ;;   # answer a pending loop approval (MERGE_APPROVAL=hermes)
  schedule)          ace_schedule "${ACE_ARG:-}" ;;                  # recurring autorun via hermes cron
  update)            update ;;
  arch|architecture) show_architecture ;;
  uninstall)         _gate_destructive uninstall && uninstall ;;
  *) err "unknown command: $cmd"; usage; exit 1 ;;
esac
